# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit actual keys.

# AI Providers — env vars are the fallback when no user-managed keys exist
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=

# App URL (for OAuth redirect URIs)
APP_URL=http://localhost:5173

# Supabase (required for user accounts)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel KV (required for email connectors)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Stripe billing (required for payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# Gmail connector (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Outlook connector (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
